pose11.position.z = z
pose11.orientation.x = qx
pose11.orientation.y = qy
pose11.orientation.z = qz
pose11.orientation.w = qw
waypoints.append(pose11)

# Point 12
pose12 = copy.deepcopy(start_pose)
