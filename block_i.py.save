waypoints.append(pose14)

# Point 15
pose15 = copy.deepcopy(start_pose)
pose15.position.x = x - delta
pose15.position.y = y + 3*delta
pose15.position.z = z
pose15.orientation.x = qx
pose15.orientation.y = qy
pose15.orientation.z = qz
pose15.orientation.w = qw
