pose10.position.z = z
pose10.orientation.x = qx
pose10.orientation.y = qy
pose10.orientation.z = qz
pose10.orientation.w = qw
waypoints.append(pose10)

# Point 11
pose11 = copy.deepcopy(start_pose)
